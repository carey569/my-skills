# test-specs/<module-name>.yaml
# 由 /auto-dev spec 生成，人审批后冻结

spec_id: ""                   # 规格 ID (如 FEAT-001)
title: ""                     # 功能名称
module: ""                    # 模块路径
source: ""                    # 来源文档路径
approved: false               # 人审批后改为 true

cases:
  - id: ""                    # 用例 ID (如 TC-001)
    name: ""                  # 测试函数名 (英文 snake_case)
    description: ""           # 中文描述
    preconditions:            # 前置条件 (自然语言)
      - ""
    input:                    # 输入参数 (key-value)
      key: "value"
    expect:                   # 预期断言 (自然语言)
      - "response.xxx == yyy"
    priority: P1              # P0 / P1 / P2
    edge_cases:               # 边界条件 (可选)
      - name: ""
        input: {}
        expect: []
