#!/usr/bin/env bash
# verify.sh — 端到端验证脚本
# 由 /auto-dev-spec 根据项目技术栈生成，人审批后冻结
set -euo pipefail

# ============================================================
# 框架函数
# ============================================================

PASS=0
FAIL=0
FAILURES=()

check() {
  local name="$1"
  shift
  echo -n "[CHECK] ${name} ... "
  if output=$("$@" 2>&1); then
    echo "PASS"
    ((PASS++))
  else
    echo "FAIL"
    ((FAIL++))
    FAILURES+=("${name}")
    echo "  ↳ ${output}" | head -20
  fi
}

inject() {
  # 测试注入端点：在验证前注入测试数据或 mock 配置
  # 用法: inject <endpoint> <payload_file>
  local endpoint="$1"
  local payload="${2:-}"
  if [[ -n "${payload}" && -f "${payload}" ]]; then
    curl -sf -X POST "${endpoint}" -H "Content-Type: application/json" -d @"${payload}"
  else
    curl -sf -X POST "${endpoint}"
  fi
}

# ============================================================
# Phase 0: 冻结文件校验
# ============================================================

echo "=== Phase 0: 冻结文件校验 ==="

# 校验冻结文件的完整性
# 从 .auto-dev.yaml 读取 frozen_checksums 并验证
if [ -f ".auto-dev.yaml" ]; then
  FROZEN_OK=true
  # TODO: 由 /auto-dev-spec 根据 frozen_files 和 frozen_checksums 填充
  # 示例:
  # EXPECTED="a1b2c3d4..."
  # ACTUAL=$(shasum -a 256 test-specs/xxx.yaml | awk '{print $1}')
  # if [ "$EXPECTED" != "$ACTUAL" ]; then
  #   echo "FAIL: test-specs/xxx.yaml checksum mismatch"
  #   FROZEN_OK=false
  # fi

  if [ "$FROZEN_OK" = true ]; then
    echo "  All frozen files verified ✓"
  else
    echo "  ERROR: Frozen file integrity check failed!"
    echo "  Aborting verification — frozen files may have been tampered with."
    exit 2
  fi
else
  echo "  No .auto-dev.yaml found, skipping frozen file check"
fi

# ============================================================
# Phase 1: 基础设施检查
# ============================================================

echo ""
echo "=== Phase 1: 基础设施检查 ==="

# TODO: 由 /auto-dev-spec 根据 .auto-dev.yaml 中的 infra 配置填充
