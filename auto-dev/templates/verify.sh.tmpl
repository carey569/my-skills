echo ""
echo "=== Phase 2: 测试数据准备 ==="

# TODO: 由 /auto-dev-spec 根据 test-specs 填充
# 示例:
# inject "http://localhost:8080/test/seed" fixtures/seed.json

echo "(no test data steps configured)"

# ============================================================
