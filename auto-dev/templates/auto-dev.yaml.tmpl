# .auto-dev.yaml — auto-dev skill 项目配置
# 由 /auto-dev init 自动生成，可手动调整

version: "0.2.0"

project:
  name: ""                    # 项目名称
  language: ""                # go / python / typescript / rust / java
  root: "."                   # 项目根路径

commands:
  test: ""                    # 项目的测试命令
  build: ""                   # 项目的构建命令
  lint: ""                    # 项目的 lint 命令 (可选)

infra:
  container: null             # docker-compose / dockerfile / null
  compose_file: ""            # docker-compose 文件路径
  health_check: ""            # 健康检查命令
  databases: []               # 检测到的数据库列表 (mysql / postgres / sqlite / mongo)
  caches: []                  # 检测到的缓存列表 (redis / memcached)
  message_queues: []          # 检测到的消息队列列表 (kafka / rabbitmq)

policy:
  unit_max_retries: 5         # 单元测试自愈上限
  integration_max_retries: 3  # 集成测试自愈上限
  complexity_threshold: 3     # 改几个文件以上算 L 级别
  require_approval: true      # 是否要求人审批验证方案

# 多模块支持 (monorepo)
# 如果项目是 monorepo，在此列出各子模块
# modules:
#   - name: "frontend"
#     root: "packages/frontend"
#     language: "typescript"
#     commands:
#       test: "npm test"
#       build: "npm run build"
#   - name: "backend"
#     root: "services/api"
#     language: "go"
#     commands:
#       test: "go test ./..."
#       build: "go build ./cmd/server"

frozen_files: []              # Phase B 审批后自动追加
frozen_checksums: {}          # frozen_files 的 SHA-256 校验和

test_specs_dir: test-specs
progress_dir: .progress
